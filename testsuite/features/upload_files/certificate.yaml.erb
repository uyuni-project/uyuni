apiVersion: cert-manager.io/v1
kind: Certificate
metadata:
  name: <%= name %>
<% if namespace -%>
  namespace: <%= namespace %>
<% end -%>
spec:
  secretName: <%= secret_name %>
<% if is_ca == false -%>
  isCA: false
  usages:
    - server auth
  privateKey:
    algorithm: RSA
    encoding: PKCS1
    size: 2048
    rotationPolicy: Always
<% end -%>
<% if subject -%>
  subject:
    countries: ['<%= subject[:country] %>']
    provinces: ['<%= subject[:province] %>']
    localities: ['<%= subject[:locality] %>']
    organizations: ['<%= subject[:org] %>']
    organizationalUnits: ['<%= subject[:ou] %>']
  emailAddresses:
    - <%= subject[:email] %>
<% end -%>
  commonName: <%= fqdn %>
  dnsNames:
    - <%= fqdn %>
  issuerRef:
    name: <%= issuer_name %>
    kind: <%= issuer_kind %>
<% if issuer_group -%>
    group: <%= issuer_group %>
<% end -%>
