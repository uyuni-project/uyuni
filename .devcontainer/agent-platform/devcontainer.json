{
  "name": "Agent Platform Sandbox",
  "build": {
    "dockerfile": "Dockerfile",
    "args": {
      "AGENT_PLATFORM_CLAUDE_CODE_VERSION": "${localEnv:AGENT_PLATFORM_CLAUDE_CODE_VERSION:latest}",
      "AGENT_PLATFORM_CODEX_VERSION": "${localEnv:AGENT_PLATFORM_CODEX_VERSION:latest}",
      "AGENT_PLATFORM_OPENCODE_VERSION": "${localEnv:AGENT_PLATFORM_OPENCODE_VERSION:latest}",
      "AGENT_PLATFORM_BACKLOG_MD_VERSION": "${localEnv:AGENT_PLATFORM_BACKLOG_MD_VERSION:latest}",
      "AGENT_PLATFORM_BACKLOG_MD_MCP_VERSION": "${localEnv:AGENT_PLATFORM_BACKLOG_MD_MCP_VERSION:latest}",
      "AGENT_PLATFORM_BEADS_VERSION": "${localEnv:AGENT_PLATFORM_BEADS_VERSION:latest}",
      "AGENT_PLATFORM_CONTEXT7_VERSION": "${localEnv:AGENT_PLATFORM_CONTEXT7_VERSION:latest}",
      "AGENT_PLATFORM_PLAYWRIGHT_MCP_VERSION": "${localEnv:AGENT_PLATFORM_PLAYWRIGHT_MCP_VERSION:latest}",
      "AGENT_PLATFORM_ZSH_IN_DOCKER_VERSION": "${localEnv:AGENT_PLATFORM_ZSH_IN_DOCKER_VERSION:1.2.0}",
      "AGENT_PLATFORM_TRUFFLEHOG_VERSION": "${localEnv:AGENT_PLATFORM_TRUFFLEHOG_VERSION:latest}",
      "AGENT_PLATFORM_EDITOR": "${localEnv:AGENT_PLATFORM_EDITOR:nano}",
      "AGENT_PLATFORM_LANGUAGE": "${localEnv:AGENT_PLATFORM_LANGUAGE:en_US.UTF-8}",
      "AGENT_PLATFORM_TZ": "${localEnv:AGENT_PLATFORM_TZ:Europe/Warsaw}",
      "AGENT_PLATFORM_OLLAMA_BASE_URL": "${localEnv:AGENT_PLATFORM_OLLAMA_BASE_URL}"
    }
  },
  "containerEnv": {
    "AGENT_PLATFORM_ALLOW_INTERNET": "${localEnv:AGENT_PLATFORM_ALLOW_INTERNET:true}",
    "AGENT_PLATFORM_ALLOW_SSH_AGENT": "${localEnv:AGENT_PLATFORM_ALLOW_SSH_AGENT:true}",
    "AGENT_PLATFORM_ALLOW_HOST_NETWORK": "${localEnv:AGENT_PLATFORM_ALLOW_HOST_NETWORK:true}",
    "NODE_OPTIONS": "--max-old-space-size=4096",
    "POWERLEVEL9K_DISABLE_GITSTATUS": "true",
    "OPENCODE_CONFIG": "/etc/opencode/managed_config.json",
    "OPENCODE_CONFIG_DIR": "/home/node/.opencode"
  },
  "runArgs": ["--cap-add=NET_ADMIN"],
  "customizations": {
    "vscode": {
      "extensions": [
        "anthropic.claude-code",
        "openai.chatgpt",
        "github.copilot",
        "github.copilot-chat"
      ],
      "settings": {
        "github.copilot.enable": {
          "*": true
        },
        "editor.inlineSuggest.enabled": true,
        "terminal.integrated.defaultProfile.linux": "zsh",
        "terminal.integrated.profiles.linux": {
          "bash": {
            "path": "bash",
            "icon": "terminal-bash"
          },
          "zsh": {
            "path": "zsh"
          }
        }
      }
    }
  },
  "remoteUser": "node",
  "mounts": [
    "source=agent-platform-bashhistory,target=/commandhistory,type=volume",
    "source=agent-platform-claude-code-config,target=/home/node/.claude,type=volume",
    "source=agent-platform-codex-config,target=/home/node/.codex,type=volume",
    "source=agent-platform-opencode-config,target=/home/node/.opencode,type=volume"
  ],
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspace,type=bind,consistency=delegated",
  "workspaceFolder": "/workspace",
  "postStartCommand": [
    "bash",
    "-c",
    "echo \"${SSH_AUTH_SOCK:-}\" > /tmp/.vscode-ssh-auth-sock && sudo /usr/local/bin/init-firewall.sh && /usr/local/bin/access.sh"
  ],
  "waitFor": "postStartCommand"
}
