<button type="submit" name="dispatch" class="btn btn-default">
  <i class="fa fa-power-off"></i><bean:message key="kickstart.powermanagement.jsp.power_on"/>
</button>
<button type="submit" name="dispatch" class="btn btn-danger">
  <i class="fa fa-power-off"></i><bean:message key="kickstart.powermanagement.jsp.power_off" />
</button>
<button type="submit" name="dispatch" class="btn btn-default">
  <i class="fa fa-refresh"></i><bean:message key="kickstart.powermanagement.jsp.reboot"/>
</button>
