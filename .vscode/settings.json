{
    "typescript.tsdk": "./web/html/src/node_modules/typescript/lib",
    "[javascript][javascriptreact][typescript][typescriptreact][json][jsonc][css][less][scss][html]": {
        "editor.tabSize": 2,
        "files.insertFinalNewline": true,
        "editor.defaultFormatter": "dbaeumer.vscode-eslint",
        "editor.formatOnSave": true,
        "editor.codeActionsOnSave": {
            "source.fixAll.eslint": "explicit"
        },
    },
    "css.lint.emptyRules": "ignore",
    "less.lint.emptyRules": "ignore",
    "scss.lint.emptyRules": "ignore",
    "prettier.requireConfig": true,
    "java.checkstyle.configuration": "java/buildconf/checkstyle.xml",
    "ant.buildFilenames": "java/manager-build.xml",
    "java.checkstyle.version": "10.12.7",
    "java.checkstyle.autocheck": true,
    "java.checkstyle.properties": {
        "checkstyle.cache.file": "java/build/checkstyle.cache.src",
        "checkstyle.header.file": "java/buildconf/LICENSE.txt",
        "checkstyle.suppressions.file": "java/buildconf/checkstyle-suppressions.xml",
        "javadoc.lazy": false,
        "javadoc.method.scope": "public",
        "javadoc.type.scope": "package",
        "javadoc.var.scope": "package",
    }
}
