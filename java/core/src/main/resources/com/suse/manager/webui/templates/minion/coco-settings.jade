include ./minion-header.jade

#coco-settings

script(type='text/javascript').
    window.csrfToken = "#{csrf_token}";

script(type='text/javascript').
    spaImportReactPage('minion/coco/coco-settings')
        .then(function(module) {
            module.renderer('coco-settings', {
                serverId: #{server.id},
                availableEnvironmentTypes: !{availableEnvironmentTypes}
            })
        });
